{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": [
      "ES2022",
      "DOM"
    ],
    "types": [
      "@sapui5/types"
    ],
    "allowJs": false,
    "checkJs": false,
    "strict": false,
    "noEmit": true,
    "skipLibCheck": true,
    "baseUrl": "./webapp",
    "paths": {
      "c4p/mdg/mdgcreaterequest/*": [
        "./*"
      ]
    }
  },
  "include": [
    "webapp/**/*.ts"
  ],
  "exclude": [
    "dist",
    "node_modules",
    "webapp/test"
  ]
}
